                <mxCell id="cinQwkDnY9UYF4VpSvYr-24" value="&lt;p data-path-to-node=&quot;12,2,0&quot; style=&quot;font-style: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-line: none; text-decoration-thickness: auto; text-decoration-style: solid; caret-color: rgb(0, 0, 0); color: rgb(0, 0, 0);&quot;&gt;O FastAPI junta 3 coisas:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;12,2,1,0,0&quot;&gt;A pergunta do usuário.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;12,2,1,1,0&quot;&gt;O texto extraído do PDF (RAG).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;12,2,1,2,0&quot;&gt;O&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;i data-path-to-node=&quot;12,2,1,2,0&quot; data-index-in-node=&quot;2&quot;&gt;System Prompt&lt;/i&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;(Regras de escopo e Inteligência Emocional).&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
